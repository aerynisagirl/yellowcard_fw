        {
          "name": "PIC32MX_DFP",
          "vendor": "Microchip",
          "version": "1.5.259"
        }
      ],
      "fileSet": "Project files",
      "toolchain": "default-XC32",
      "postBuildSteps": [
        "${MP_CC_DIR}\\xc32-objdump -S %{TargetDirRelative}\\%{Name(%{Target})}.elf > build\\%{ConfigurationName}\\%{ImageType}\\%{ProjectName}.lst"
      ]
    }
  ],
