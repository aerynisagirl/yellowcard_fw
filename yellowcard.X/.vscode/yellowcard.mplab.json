{
  "version": "1.8",
  "importedFrom": "./",
  "configurations": [
    {
      "name": "default",
      "id": "conf1",
      "device": "PIC32MX120F032B",
      "imageType": "application",
      "imagePath": "./out/yellowcard/default.elf",
      "toolProperties": "default-tool",
      "tool": "PK5Tool",
