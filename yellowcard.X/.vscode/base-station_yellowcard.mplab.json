            "fileSet": "Project files",
            "toolchain": "production-XC32",
            "postBuildSteps": [
                "${MP_CC_DIR}\\xc32-objdump -S %{TargetDirRelative}\\%{Name(%{Target})}.elf > build\\%{ConfigurationName}\\%{ImageType}\\%{ProjectName}.lst"
            ]
        },
        {
            "name": "development",
            "id": "",
            "device": "PIC32MX120F032B",
            "imageType": "application",
            "imagePath": "./out/base-station_yellowcard/development.elf",
            "toolProperties": "development-tool",
